{
  "name": "@baicie/clean",
  "version": "0.1.3",
  "description": "Clean node_modules and target directories in workspace",
  "type": "module",
  "bin": {
    "ba-clean": "cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "cli.js"
  ],
  "scripts": {
    "dev": "rolldown --watch -c",
    "build-only": "rolldown -c",
    "build": "pnpm run clean-dist && pnpm run build-only",
    "clean-dist": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "ba-clean": "tsx ./src/cli.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "fs-extra": "^11.3.4",
    "cac": "^7.0.0",
    "tinyexec": "^1.1.2"
  },
  "devDependencies": {
    "@arnaud-barre/tnode": "^0.25.0",
    "@types/node": "^25.6.0",
    "@types/fs-extra": "^11.0.4",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.18",
    "rolldown-plugin-dts": "^0.24.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
